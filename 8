import { useState, useEffect } from 'react'
import { GoogleLogin } from '@react-oauth/google'
import jwtDecode from 'jwt-decode'
import Quiz from './components/Quiz'
import Results from './components/Results'

function App() {
  const [user, setUser] = useState(null)
  const [quizStarted, setQuizStarted] = useState(false)
  const [results, setResults] = useState(null)

  useEffect(() => {
    const savedUser = localStorage.getItem('user')
    if (savedUser) {
      setUser(JSON.parse(savedUser))
    }
  }, [])

  const handleLoginSuccess = (credentialResponse) => {
    const decoded = jwtDecode(credentialResponse.credential)
    const userData = {
      id: decoded.sub,
      email: decoded.email,
      name: decoded.name,
      picture: decoded.picture
    }
    setUser(userData)
    localStorage.setItem('user', JSON.stringify(userData))
  }

  const handleLogout = () => {
    setUser(null)
    setQuizStarted(false)
    setResults(null)
    localStorage.removeItem('user')
  }

  const handleQuizComplete = (quizResults) => {
    setResults(quizResults)
    setQuizStarted(false)
  }

  if (!user) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center p-4">
        <div className="bg-white rounded-lg shadow-2xl p-8 max-w-md w-full">
          <h1 className="text-4xl font-bold text-center mb-2 text-gray-800">Quiz Master</h1>
          <p className="text-center text-gray-600 mb-8">Test your knowledge with our interactive quizzes</p>
          <div className="flex justify-center">
            <GoogleLogin
              onSuccess={handleLoginSuccess}
              onError={() => console.log('Login Failed')}
            />
          </div>
          <p className="text-xs text-gray-500 text-center mt-6">
            Sign in with your Gmail account to get started
          </p>
        </div>
      </div>
    )
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-blue-500 to-purple-600">
      {/* Header */}
      <header className="bg-white shadow">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
          <div className="flex items-center gap-4">
            <img src={user.picture} alt={user.name} className="w-10 h-10 rounded-full" />
            <div>
              <h1 className="text-2xl font-bold text-gray-800">Quiz Master</h1>
              <p className="text-sm text-gray-600">{user.name}</p>
            </div>
          </div>
          <button
            onClick={handleLogout}
            className="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition"
          >
            Logout
          </button>
        </div>
      </header>

      {/* Main Content */}
      <main className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        {!quizStarted && !results && (
          <div className="grid md:grid-cols-2 gap-8">
            {/* Quiz Selection */}
            <div className="bg-white rounded-lg shadow-lg p-8">
              <h2 className="text-2xl font-bold mb-6 text-gray-800">Select a Quiz</h2>
              <div className="space-y-4">
                <button
                  onClick={() => setQuizStarted(true)}
                  className="w-full p-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-lg hover:shadow-lg transition transform hover:scale-105"
                >
                  <h3 className="font-bold text-lg">General Knowledge</h3>
                  <p className="text-sm opacity-90">10 questions • 5 minutes</p>
                </button>
                <button
                  onClick={() => setQuizStarted(true)}
                  className="w-full p-4 bg-gradient-to-r from-purple-500 to-purple-600 text-white rounded-lg hover:shadow-lg transition transform hover:scale-105"
                >
                  <h3 className="font-bold text-lg">Science & Nature</h3>
                  <p className="text-sm opacity-90">10 questions • 5 minutes</p>
                </button>
                <button
                  onClick={() => setQuizStarted(true)}
                  className="w-full p-4 bg-gradient-to-r from-pink-500 to-pink-600 text-white rounded-lg hover:shadow-lg transition transform hover:scale-105"
                >
                  <h3 className="font-bold text-lg">History & Culture</h3>
                  <p className="text-sm opacity-90">10 questions • 5 minutes</p>
                </button>
              </div>
            </div>

            {/* Welcome Section */}
            <div className="bg-white rounded-lg shadow-lg p-8">
              <h2 className="text-2xl font-bold mb-4 text-gray-800">Welcome, {user.name}!</h2>
              <div className="space-y-4 text-gray-700">
                <p>
                  Welcome to Quiz Master, your interactive platform for testing and improving your knowledge.
                </p>
                <div className="bg-blue-50 p-4 rounded-lg">
                  <h3 className="font-bold mb-2">How it works:</h3>
                  <ol className="list-decimal list-inside space-y-2 text-sm">
                    <li>Choose a quiz from the left</li>
                    <li>Answer all questions</li>
                    <li>View your results and score</li>
                    <li>Retake quizzes to improve</li>
                  </ol>
                </div>
                <p className="text-sm text-gray-600">
                  Each quiz contains multiple choice questions. Select the best answer for each question.
                </p>
              </div>
            </div>
          </div>
        )}

        {quizStarted && <Quiz onComplete={handleQuizComplete} />}
        {results && <Results results={results} onRetry={() => setResults(null)} />}
      </main>
    </div>
  )
}

export default App
